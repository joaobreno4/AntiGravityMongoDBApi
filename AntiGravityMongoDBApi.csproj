<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>AntiGravityMongoDBApi</RootNamespace>
  </PropertyGroup>

  <!-- Exclui microsserviços com projetos próprios da compilação desta API -->
  <ItemGroup>
    <Compile Remove="AntiGravityAuditService/**" />
  </ItemGroup>

  <!-- Dependências orbitando e acopladas à API -->
  <ItemGroup>
    <PackageReference Include="MongoDB.Driver" Version="2.25.0" />
  </ItemGroup>

</Project>
